---
import { getCollection } from 'astro:content';

const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);
---
<section id="faq">
  <div class="section-inner">
    <div class="reveal" style="max-width: 740px">
      <span class="eyebrow">FAQ</span>
      <h2 class="section-title">Questions<br/>before the <span class="accent-pink">chaos</span>.</h2>
    </div>
    <div class="faq-list">
      {faqs.map(async (f, i) => {
        const { Content } = await f.render();
        return (
          <details class="faq-item reveal" open={i === 0}>
            <summary>
              <span>{f.data.question}</span>
              <span class="icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer"><Content /></div>
          </details>
        );
      })}
    </div>
  </div>
</section>

<style>
  .faq-list {
    margin-top: 60px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 30px 0;
    transition: padding 0.3s;
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    list-style: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: clamp(24px, 2.5vw, 34px);
    line-height: 1.15;
    letter-spacing: -0.5px;
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary .icon {
    width: 38px;
    height: 38px;
    border: 2px solid var(--bsp-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s, background 0.3s, border-color 0.3s;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 20px;
  }
  .faq-item[open] summary { color: var(--bsp-cyan); }
  .faq-item[open] summary .icon {
    transform: rotate(45deg);
    background: var(--bsp-cyan);
    border-color: var(--bsp-cyan);
    color: var(--bsp-black);
  }
  .faq-item:hover summary { color: var(--bsp-cyan); }
  .faq-answer {
    margin-top: 18px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 17px;
    line-height: 1.65;
    max-width: 820px;
  }
  .faq-answer :global(a) {
    color: var(--bsp-cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .faq-answer :global(p) { margin-bottom: 12px; }
  .faq-answer :global(p:last-child) { margin-bottom: 0; }
  .faq-answer :global(ul) { margin: 12px 0; padding-left: 20px; }
  .faq-answer :global(li) { margin-bottom: 6px; }
</style>
