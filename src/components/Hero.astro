---
// Hero: the first impression. Big type, animated card stack, floating mascot, sticker.
---
<header class="hero">
  <div class="hero-inner">
  <div class="hero-content">
    <div class="hero-kicker">
      <span class="dot"></span>Now Shipping — US · UK · Canada
    </div>
    <h1>
      <span class="line-1">Get</span>
      <span class="line-2">Everyone</span>
      <span class="line-3">Talking.</span>
    </h1>
    <p class="hero-sub">
      150 outrageous questions. Two-minute setup. Different every game.
      The party card game that makes friends tell on themselves — and somehow still stay friends.
    </p>
    <div class="hero-ctas">
      <a href="https://shop.blacksheeppartygame.com" class="btn">Shop Black Sheep</a>
      <a href="#how" class="btn btn-outline">How it works</a>
    </div>
    <div class="sticker sticker-1" aria-hidden="true">
      Your friend group will not survive this
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><div class="num">150</div><div class="label">Questions</div></div>
      <div class="hero-meta-item"><div class="num">3–10</div><div class="label">Players</div></div>
      <div class="hero-meta-item"><div class="num">2<span style="font-size: 0.5em">min</span></div><div class="label">To Learn</div></div>
    </div>
  </div>

  <div class="card-stack reveal reveal-2" aria-hidden="true">
    <div class="card card-1"><img src="/images/cards/front/028.webp" alt="Card #028" /></div>
    <div class="card card-2"><img src="/images/cards/front/051.webp" alt="Card #051" /></div>
    <div class="card card-3"><img src="/images/cards/front/102.webp" alt="Card #102" /></div>
    <div class="card card-4"><img src="/images/cards/front/146.webp" alt="Card #146" /></div>
  </div>

  </div><!-- /hero-inner -->

  <div class="mascot" aria-hidden="true">
    <img src="/images/logos/logo-original.png" alt="" width="100" height="100" />
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    overflow: clip;
    isolation: isolate;
    z-index: 2;
  }
  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: 40px;
    padding: 48px var(--content-padding) 100px;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: -100%;
    z-index: -2;
    background: repeating-conic-gradient(
      from 0deg at 68% 52%,
      rgba(255, 255, 255, 0.04) 0deg 5deg,
      transparent 5deg 11deg
    );
    animation: slow-spin 180s linear infinite;
  }
  @keyframes slow-spin { to { transform: rotate(360deg); } }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 900px 700px at 75% 45%, rgba(0, 180, 255, 0.18), transparent 60%),
      radial-gradient(ellipse 800px 600px at 15% 85%, rgba(255, 31, 142, 0.14), transparent 55%),
      radial-gradient(circle at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  }

  .hero-content { position: relative; z-index: 3; max-width: 720px; }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--bsp-cyan);
    margin-bottom: 32px;
    padding: 9px 16px;
    border: 1px solid rgba(0, 180, 255, 0.4);
    border-radius: 999px;
    background: rgba(0, 180, 255, 0.06);
  }
  .hero-kicker .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--bsp-cyan);
    box-shadow: 0 0 14px var(--bsp-cyan);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.5); }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(60px, 9vw, 140px);
    line-height: 0.88;
    letter-spacing: -2px;
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  .hero h1 .line-1 { display: block; }
  .hero h1 .line-2 { color: var(--bsp-cyan); display: block; }
  .hero h1 .line-3 {
    color: var(--bsp-pink); display: block;
    transform: translateX(40px); position: relative;
  }
  .hero h1 .line-3::after {
    content: '';
    position: absolute;
    left: -8px; bottom: -12px;
    width: calc(100% - 20px); height: 14px;
    background: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 14'%3E%3Cpath d='M2 10 Q 50 2, 100 8 T 200 7 T 300 9 T 398 6' stroke='%2300B4FF' stroke-width='4' fill='none' stroke-linecap='round'/%3E%3C/svg%3E")
      no-repeat center / 100% 100%;
  }

  .hero-sub {
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
    max-width: 560px;
    margin-bottom: 44px;
  }

  .hero-ctas { display: flex; gap: 20px; flex-wrap: wrap; align-items: center; margin-bottom: 28px; }

  /* Sticker — now inside content col, below CTAs, visible and not overlapping copy */
  .sticker {
    display: inline-block;
    background: var(--bsp-white);
    color: var(--bsp-black);
    padding: 12px 18px;
    font-family: var(--font-marker);
    font-size: 16px;
    transform: rotate(-2deg);
    box-shadow: 3px 3px 0 var(--bsp-pink), 0 6px 16px rgba(0, 0, 0, 0.35);
    border: 2px solid var(--bsp-black);
    margin-bottom: 36px;
    position: relative;
  }
  .sticker::before {
    content: '';
    position: absolute;
    top: -8px; left: 50%;
    transform: translateX(-50%);
    width: 30px; height: 12px;
    background: rgba(0, 180, 255, 0.5);
    border: 1px dashed var(--bsp-black);
  }

  .hero-meta {
    display: flex;
    gap: 50px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .hero-meta-item .num {
    font-family: var(--font-display);
    font-size: clamp(36px, 3.5vw, 52px);
    line-height: 1;
    color: var(--bsp-white);
    margin-bottom: 8px;
  }
  .hero-meta-item .label {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bsp-grey);
    font-weight: 700;
  }

  /* Card stack — individual card hover brings to front */
  .card-stack {
    position: relative;
    width: 100%;
    height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    perspective: 1200px;
  }
  .card {
    position: absolute;
    width: 280px;
    height: 400px;
    border-radius: 18px;
    overflow: hidden;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.55);
    transition: transform 0.7s cubic-bezier(0.2, 0.9, 0.3, 1.3);
    will-change: transform;
    cursor: pointer;
  }
  .card img { width: 100%; height: 100%; object-fit: cover; display: block; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.6)); }

  .card-1 { transform: translate(-130px, 30px) rotate(-14deg); z-index: 1; }
  .card-2 { transform: translate(-20px, -20px) rotate(-2deg); z-index: 2; }
  .card-3 { transform: translate(110px, 50px) rotate(11deg); z-index: 1; }
  .card-4 {
    transform: translate(50px, -80px) rotate(-3deg);
    z-index: 3;
    animation: card-float 4.5s ease-in-out infinite;
  }
  @keyframes card-float {
    0%, 100% { transform: translate(50px, -80px) rotate(-3deg); }
    50% { transform: translate(50px, -92px) rotate(-4deg); }
  }

  /* Hover individual card — lift slightly */
  .card-1:hover { transform: translate(-130px, 10px) rotate(-8deg) scale(1.04); z-index: 10; }
  .card-2:hover { transform: translate(-20px, -40px) rotate(0deg) scale(1.04); z-index: 10; }
  .card-3:hover { transform: translate(110px, 20px) rotate(5deg) scale(1.04); z-index: 10; }
  .card-4:hover { transform: translate(50px, -100px) rotate(0deg) scale(1.04); z-index: 10; animation: none; }

  /* Click — snap card to centre front */
  .card--active {
    transform: translate(0, -20px) rotate(0deg) scale(1.1) !important;
    z-index: 10 !important;
    animation: none !important;
  }

  /* Mascot */
  .mascot {
    position: absolute;
    top: 12%; right: 2%;
    width: 100px; height: 100px;
    z-index: 4;
    animation: mascot-bob 6s ease-in-out infinite;
    filter: drop-shadow(0 10px 20px rgba(0, 180, 255, 0.3));
  }
  .mascot img {
    width: 100%; height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--bsp-cyan);
  }
  @keyframes mascot-bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-14px) rotate(4deg); }
  }

  /* Compact layout for short viewports (13" laptops, ~800px tall) */
  @media (max-height: 820px) and (min-width: 1100px) {
    .hero h1 { font-size: clamp(56px, 7vw, 100px); margin-bottom: 20px; }
    .hero-kicker { margin-bottom: 20px; }
    .hero-sub { margin-bottom: 28px; }
    .hero-ctas { margin-bottom: 16px; }
    .sticker { margin-bottom: 20px; }
    .hero-meta { padding-top: 20px; }
    .hero-inner { padding-top: 32px; padding-bottom: 60px; }
  }

  @media (max-width: 1100px) {
    .hero { min-height: auto; }
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 50px var(--content-padding) 80px;
    }
    .card-stack { height: 400px; margin-top: 24px; }
    .mascot { top: 5%; right: 5%; width: 80px; height: 80px; }
  }
  @media (max-width: 620px) {
    .hero-inner { padding: 32px var(--content-padding) 16px; }
    .hero h1 { font-size: clamp(46px, 13vw, 72px); margin-bottom: 20px; }
    .hero h1 .line-3 { transform: translateX(16px); }
    .hero-sub { margin-bottom: 28px; font-size: 16px; }
    .hero-ctas { flex-direction: column; align-items: stretch; gap: 12px; margin-bottom: 20px; }
    .hero-ctas .btn { text-align: center; }
    .sticker { font-size: 14px; margin-bottom: 24px; }
    .hero-meta { gap: 30px; flex-wrap: wrap; padding-top: 20px; }
    .card-stack { height: 380px; margin-top: -30px; }
    .card { width: 180px; height: 260px; }
    .card-1 { transform: translate(-80px, 20px) rotate(-14deg); }
    .card-2 { transform: translate(-10px, -10px) rotate(-2deg); }
    .card-3 { transform: translate(70px, 30px) rotate(11deg); }
    .card-4 { transform: translate(30px, -50px) rotate(-3deg); animation: none; }
  }
</style>

<script>
  const cards = document.querySelectorAll('.hero .card');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const isActive = card.classList.contains('card--active');
      cards.forEach((c) => c.classList.remove('card--active'));
      if (!isActive) card.classList.add('card--active');
    });
  });
</script>
