---
// Hero: the first impression. Big type, animated card stack, floating mascot, sticker.
---
<header class="hero">
  <div class="hero-content reveal">
    <div class="hero-kicker">
      <span class="dot"></span>Now Shipping — US · UK · Canada
    </div>
    <h1>
      <span class="line-1">Get</span>
      <span class="line-2">Everyone</span>
      <span class="line-3">Talking.</span>
    </h1>
    <p class="hero-sub">
      150 outrageous questions. Two-minute setup. Different every game.
      The party card game that makes friends tell on themselves — and somehow still stay friends.
    </p>
    <div class="hero-ctas">
      <a href="https://shop.blacksheeppartygame.com" class="btn">Shop Black Sheep</a>
      <a href="#how" class="btn btn-outline">How it works</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><div class="num">150</div><div class="label">Questions</div></div>
      <div class="hero-meta-item"><div class="num">3–10</div><div class="label">Players</div></div>
      <div class="hero-meta-item"><div class="num">2<span style="font-size: 0.5em">min</span></div><div class="label">To Learn</div></div>
    </div>
  </div>

  <div class="card-stack reveal reveal-2" aria-hidden="true">
    <div class="card card-1">
      <div class="card-label">Yes / No</div>
      <div class="card-q">Have you ever ghosted someone mid-date?</div>
      <div class="card-footer"><span>#047</span><span>✦</span></div>
    </div>
    <div class="card card-2">
      <div class="card-label">Nominate</div>
      <div class="card-q">Most likely to start a cult.</div>
      <div class="card-footer"><span>#112</span><span>A / B</span></div>
    </div>
    <div class="card card-3">
      <div class="card-label">Yes / No</div>
      <div class="card-q">Have you lied on a CV to get a job?</div>
      <div class="card-footer"><span>#089</span><span>✦</span></div>
    </div>
    <div class="card card-4">
      <div class="card-label" style="color: var(--bsp-cyan)">Black Sheep</div>
      <div class="card-q card-q-display">Play<br/>The<br/>Game.</div>
      <div class="card-footer"><span style="color: var(--bsp-pink)">150 CARDS</span><span style="color: var(--bsp-cyan)">✦</span></div>
    </div>
  </div>

  <div class="mascot" aria-hidden="true">
    <img src="/images/logos/logo-small.webp" alt="" width="100" height="100" />
  </div>

  <div class="sticker sticker-1" aria-hidden="true">
    Your friend group will not survive this
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: 40px;
    padding: 70px var(--content-padding) 120px;
    overflow: hidden;
    isolation: isolate;
    z-index: 2;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: -30%;
    z-index: -2;
    background: repeating-conic-gradient(
      from 0deg at 68% 52%,
      rgba(255, 255, 255, 0.04) 0deg 5deg,
      transparent 5deg 11deg
    );
    animation: slow-spin 180s linear infinite;
  }
  @keyframes slow-spin {
    to { transform: rotate(360deg); }
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 900px 700px at 75% 45%, rgba(0, 180, 255, 0.18), transparent 60%),
      radial-gradient(ellipse 800px 600px at 15% 85%, rgba(255, 31, 142, 0.14), transparent 55%),
      radial-gradient(circle at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  }

  .hero-content { position: relative; z-index: 3; max-width: 720px; }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--bsp-cyan);
    margin-bottom: 32px;
    padding: 9px 16px;
    border: 1px solid rgba(0, 180, 255, 0.4);
    border-radius: 999px;
    background: rgba(0, 180, 255, 0.06);
  }
  .hero-kicker .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bsp-cyan);
    box-shadow: 0 0 14px var(--bsp-cyan);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.5); }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(60px, 9vw, 140px);
    line-height: 0.88;
    letter-spacing: -2px;
    text-transform: uppercase;
    margin-bottom: 32px;
    position: relative;
  }
  .hero h1 .line-1 { display: block; }
  .hero h1 .line-2 { color: var(--bsp-cyan); display: block; }
  .hero h1 .line-3 {
    color: var(--bsp-pink);
    display: block;
    transform: translateX(40px);
    position: relative;
  }
  .hero h1 .line-3::after {
    content: '';
    position: absolute;
    left: -8px;
    bottom: -12px;
    width: calc(100% - 20px);
    height: 14px;
    background: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 14'%3E%3Cpath d='M2 10 Q 50 2, 100 8 T 200 7 T 300 9 T 398 6' stroke='%2300B4FF' stroke-width='4' fill='none' stroke-linecap='round'/%3E%3C/svg%3E")
      no-repeat center / 100% 100%;
  }

  .hero-sub {
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
    max-width: 560px;
    margin-bottom: 44px;
  }

  .hero-ctas { display: flex; gap: 20px; flex-wrap: wrap; align-items: center; }

  .hero-meta {
    display: flex;
    gap: 50px;
    margin-top: 60px;
    padding-top: 36px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .hero-meta-item .num {
    font-family: var(--font-display);
    font-size: clamp(36px, 3.5vw, 52px);
    line-height: 1;
    color: var(--bsp-white);
    margin-bottom: 8px;
  }
  .hero-meta-item .label {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bsp-grey);
    font-weight: 700;
  }

  /* Card stack */
  .card-stack {
    position: relative;
    width: 100%;
    height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    perspective: 1200px;
  }
  .card {
    position: absolute;
    width: 280px;
    height: 400px;
    border-radius: 18px;
    padding: 28px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.55), 0 0 0 2px rgba(0, 0, 0, 0.8);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.7s cubic-bezier(0.2, 0.9, 0.3, 1.3);
    will-change: transform;
  }
  .card-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .card-q {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.05;
    letter-spacing: -0.5px;
  }
  .card-q-display {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 38px;
    letter-spacing: 1px;
    line-height: 0.95;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 1.5px;
    font-weight: 700;
    opacity: 0.55;
  }

  .card-1 { background: var(--bsp-cyan); color: var(--bsp-black); transform: translate(-130px, 30px) rotate(-14deg); }
  .card-2 { background: var(--bsp-white); color: var(--bsp-black); transform: translate(-20px, -20px) rotate(-2deg); z-index: 2; }
  .card-3 { background: var(--bsp-pink); color: var(--bsp-white); transform: translate(110px, 50px) rotate(11deg); }
  .card-4 {
    background: var(--bsp-black);
    color: var(--bsp-white);
    border: 2px solid var(--bsp-cyan);
    transform: translate(50px, -80px) rotate(-3deg);
    z-index: 3;
    animation: card-float 4.5s ease-in-out infinite;
  }
  @keyframes card-float {
    0%, 100% { transform: translate(50px, -80px) rotate(-3deg); }
    50% { transform: translate(50px, -92px) rotate(-4deg); }
  }

  .card-stack:hover .card-1 { transform: translate(-180px, 60px) rotate(-20deg); }
  .card-stack:hover .card-2 { transform: translate(-60px, -35px) rotate(-5deg); }
  .card-stack:hover .card-3 { transform: translate(180px, 70px) rotate(18deg); }
  .card-stack:hover .card-4 { transform: translate(70px, -110px) rotate(2deg); animation: none; }

  /* Mascot */
  .mascot {
    position: absolute;
    top: 12%;
    right: 2%;
    width: 100px;
    height: 100px;
    z-index: 4;
    animation: mascot-bob 6s ease-in-out infinite;
    filter: drop-shadow(0 10px 20px rgba(0, 180, 255, 0.3));
  }
  .mascot img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--bsp-cyan);
  }
  @keyframes mascot-bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-14px) rotate(4deg); }
  }

  /* Sticker */
  .sticker {
    position: absolute;
    background: var(--bsp-white);
    color: var(--bsp-black);
    padding: 14px 20px;
    font-family: var(--font-marker);
    font-size: 18px;
    transform: rotate(-6deg);
    box-shadow: 4px 4px 0 var(--bsp-pink), 0 8px 20px rgba(0, 0, 0, 0.4);
    z-index: 5;
    pointer-events: none;
  }
  .sticker-1 {
    top: 48%;
    left: 8%;
    border: 2px solid var(--bsp-black);
  }
  .sticker-1::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 36px;
    height: 14px;
    background: rgba(0, 180, 255, 0.5);
    border: 1px dashed var(--bsp-black);
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 50px var(--content-padding) 80px;
      min-height: auto;
    }
    .card-stack { height: 460px; margin-top: 50px; }
    .sticker-1 { display: none; }
    .mascot { top: 5%; right: 5%; width: 80px; height: 80px; }
  }
  @media (max-width: 620px) {
    .hero h1 { font-size: clamp(46px, 13vw, 72px); }
    .hero h1 .line-3 { transform: translateX(16px); }
    .hero-meta { gap: 30px; flex-wrap: wrap; }
    .card-stack { height: 520px; }
    .card { width: 230px; height: 340px; padding: 22px; }
    .card-q { font-size: 24px; }
  }
</style>
