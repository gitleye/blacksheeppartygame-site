---
// Promo video — YouTube embed, constrained to content width
---
<section class="video-section">
  <div class="section-inner">
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/ox9uyaNCHLo?autoplay=1&mute=1&loop=1&playlist=ox9uyaNCHLo&rel=0&modestbranding=1"
        title="Black Sheep Party Game — Promo"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .video-section {
    background: var(--bsp-black);
  }
  .video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
  }
  .video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
</style>
