---
export interface Props {
  items: string[];
  variant?: 'cyan' | 'pink';
}
const { items, variant = 'cyan' } = Astro.props;
const track = [...items, ...items];
---
<div class={`strip strip-${variant}`} aria-hidden="true">
  <div class="strip-track">
    {track.map((t) => (
      <span class="strip-item">{t}</span>
    ))}
  </div>
</div>

<style>
  .strip {
    padding: 22px 0;
    overflow: hidden;
    border-top: 2px solid var(--bsp-black);
    border-bottom: 2px solid var(--bsp-black);
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    text-transform: uppercase;
    line-height: 1;
    position: relative;
    z-index: 2;
  }
  .strip-cyan { background: var(--bsp-cyan); color: var(--bsp-black); }
  .strip-pink { background: var(--bsp-pink); color: var(--bsp-white); }

  .strip-track {
    display: inline-flex;
    align-items: center;
    gap: 56px;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
    will-change: transform;
  }

  .strip-item {
    letter-spacing: -1px;
    display: inline-flex;
    align-items: center;
    gap: 56px;
  }
  .strip-item::after {
    content: '✦';
  }
  .strip-cyan .strip-item::after { color: var(--bsp-pink); }
  .strip-pink .strip-item::after { color: var(--bsp-black); }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
