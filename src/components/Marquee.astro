---
export interface Props {
  /** Phrases to scroll across the strip */
  items: string[];
  /** Colour theme */
  variant?: 'cyan' | 'pink';
}
const { items, variant = 'cyan' } = Astro.props;
const track = [...items, ...items];
---
<div class={`strip strip-${variant}`} aria-hidden="true">
  <div class="strip-track">
    {track.map((t) => <span>{t}</span>)}
  </div>
</div>

<style>
  .strip {
    padding: 22px 0;
    overflow: hidden;
    border-top: 2px solid var(--bsp-black);
    border-bottom: 2px solid var(--bsp-black);
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    text-transform: uppercase;
    line-height: 1;
    position: relative;
    z-index: 2;
  }
  .strip-cyan { background: var(--bsp-cyan); color: var(--bsp-black); }
  .strip-pink { background: var(--bsp-pink); color: var(--bsp-white); }

  .strip-track {
    display: inline-flex;
    gap: 60px;
    animation: marquee 40s linear infinite;
    white-space: nowrap;
    will-change: transform;
  }
  .strip-track span {
    display: inline-flex;
    align-items: center;
    gap: 60px;
    letter-spacing: -1px;
  }
  .strip-cyan .strip-track span::after {
    content: '✦';
    color: var(--bsp-pink);
    margin-left: 60px;
  }
  .strip-pink .strip-track span::after {
    content: '✦';
    color: var(--bsp-black);
    margin-left: 60px;
  }
</style>
