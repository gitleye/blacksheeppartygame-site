---
const links = [
  { href: '/how-to-play/', label: 'How to Play' },
  { href: '/#cards', label: 'The Cards' },
  { href: '/#reviews', label: 'Reviews' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/support/', label: 'Support' },
];
const currentPath = Astro.url.pathname;
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Black Sheep Party Game home">
      <img src="/images/logos/logo-small.webp" alt="" width="46" height="46" />
      <span class="nav-logo-text">
        <span class="cyan">Black</span> <span class="pink">Sheep</span>
      </span>
    </a>

    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} class:list={{ active: currentPath === l.href }}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="https://shop.blacksheeppartygame.com" class="btn btn-nav">Shop Now →</a>

    <button class="nav-burger" aria-label="Open menu" aria-expanded="false" id="navBurger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="navMobile" hidden>
    <ul>
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      <li><a href="https://shop.blacksheeppartygame.com" class="mobile-shop">Shop Now →</a></li>
    </ul>
  </div>
</nav>

<script>
  const burger = document.getElementById('navBurger');
  const mobile = document.getElementById('navMobile');

  function closeNav() {
    mobile?.setAttribute('hidden', '');
    burger?.setAttribute('aria-expanded', 'false');
    burger?.classList.remove('open');
  }

  if (burger && mobile) {
    burger.addEventListener('click', () => {
      const open = !mobile.hasAttribute('hidden');
      if (open) {
        closeNav();
      } else {
        mobile.removeAttribute('hidden');
        burger.setAttribute('aria-expanded', 'true');
        burger.classList.add('open');
      }
    });

    // Close nav when any link is tapped
    mobile.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeNav());
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 15;
    background: rgba(10, 10, 10, 0.78);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 14px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--bsp-white);
  }
  .nav-logo img {
    width: 46px;
    height: 46px;
    object-fit: contain;
    border-radius: 10px;
  }
  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 0.9;
  }
  .nav-logo-text .cyan { color: var(--bsp-cyan); }
  .nav-logo-text .pink { color: var(--bsp-pink); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    color: var(--bsp-white);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    position: relative;
    padding: 6px 0;
    transition: color 0.2s;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -2px;
    height: 2px;
    background: var(--bsp-cyan);
    transition: right 0.3s ease;
  }
  .nav-links a:hover,
  .nav-links a.active { color: var(--bsp-cyan); }
  .nav-links a:hover::after,
  .nav-links a.active::after { right: 0; }

  .btn-nav {
    padding: 11px 22px;
    box-shadow: 4px 4px 0 var(--bsp-cyan);
    font-size: 12px;
  }
  .btn-nav:hover { box-shadow: 6px 6px 0 var(--bsp-cyan); }

  /* Mobile burger */
  .nav-burger {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    padding: 0;
    position: relative;
  }
  .nav-burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--bsp-white);
    margin: 5px auto;
    transition: all 0.3s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    background: var(--bsp-black);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nav-mobile ul {
    list-style: none;
    padding: 16px 24px;
  }
  .nav-mobile li { padding: 12px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  .nav-mobile li:last-child { border-bottom: none; padding-top: 20px; }
  .nav-mobile a {
    color: var(--bsp-white);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .nav-mobile .mobile-shop {
    display: inline-block;
    background: var(--bsp-pink);
    padding: 12px 24px;
    box-shadow: 4px 4px 0 var(--bsp-cyan);
  }

  @media (max-width: 1024px) {
    .nav-inner { padding: 12px 20px; gap: 16px; }
    .nav-links { display: none; }
    .btn-nav { display: none; }
    .nav-burger { display: block; }
  }
</style>
