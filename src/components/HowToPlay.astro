---
const steps = [
  {
    num: '01',
    title: 'Set up the table',
    body: 'Lay out 15–25 question cards. Put point tokens in a bowl. Give everyone a Yes/No card.',
  },
  {
    num: '02',
    title: 'Draw & read',
    body: 'Player wearing the most black goes first. Pick a card, read it out loud, chaos ensues.',
  },
  {
    num: '03',
    title: 'Vote face down',
    body: 'Everyone plays a Yes/No or nominates A/B face down. Flip to reveal. Majority wins points.',
  },
  {
    num: '04',
    title: 'Fewest points wins',
    body: 'When the tokens run out, the player with the fewest is the Black Sheep — you win by losing.',
  },
];
---
<section id="how">
  <div class="section-inner">
    <div class="reveal" style="max-width: 820px">
      <span class="eyebrow">How to Play</span>
      <h2 class="section-title">Four steps.<br/>Zero <span class="accent-cyan">brainpower</span><br/>required.</h2>
    </div>
    <div class="steps-grid">
      {steps.map((s, i) => (
        <div class={`step reveal reveal-${i + 1}`}>
          <div class="step-num">{s.num}</div>
          <h4>{s.title}</h4>
          <p set:html={s.body.replace('Black Sheep', '<strong style="color:var(--bsp-pink)">Black Sheep</strong>')}></p>
        </div>
      ))}
    </div>
    <div style="margin-top: 52px" class="reveal">
      <a href="/how-to-play/" class="btn btn-cyan">Read full rules</a>
    </div>
  </div>
</section>

<style>
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 64px;
  }
  .step {
    background: var(--bsp-ink);
    padding: 36px 30px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
  }
  .step::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--bsp-cyan);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .step:nth-child(even)::before { background: var(--bsp-pink); }
  .step:hover { transform: translateY(-8px); border-color: rgba(255, 255, 255, 0.22); }
  .step:hover::before { transform: scaleX(1); }

  .step-num {
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 1;
    color: var(--bsp-cyan);
    margin-bottom: 20px;
  }
  .step:nth-child(even) .step-num { color: var(--bsp-pink); }
  .step h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 20px;
    margin-bottom: 14px;
    line-height: 1.2;
    letter-spacing: -0.2px;
  }
  .step p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 15px;
    line-height: 1.6;
  }

  @media (max-width: 1100px) { .steps-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .steps-grid { grid-template-columns: 1fr; } }
</style>
