---
const steps = [
  {
    num: '01',
    title: 'Set up the table',
    body: 'Lay out 15–25 question cards. Put tokens in a bowl. Give everyone a Yes/No card.',
    color: 'var(--bsp-cyan)',
  },
  {
    num: '02',
    title: 'Draw & read',
    body: 'Player wearing the most black goes first. Pick a card, read it out loud, chaos ensues.',
    color: 'var(--bsp-pink)',
  },
  {
    num: '03',
    title: 'Vote face down',
    body: 'Everyone plays Yes/No or nominates A/B face down. Flip to reveal. Majority wins points.',
    color: 'var(--bsp-cyan)',
  },
  {
    num: '04',
    title: 'Fewest points wins',
    body: 'When the tokens run out, the player with fewest points is the Black Sheep. One loses. Everyone else wins.',
    color: 'var(--bsp-pink)',
  },
];
---
<section id="how">
  <div class="section-inner">
    <div class="reveal" style="max-width: 820px">
      <span class="eyebrow">How to Play</span>
      <h2 class="section-title how-title">Four steps.<br/>Zero <span class="accent-cyan">brainpower</span> required.</h2>
    </div>

    <div class="steps-grid">
      {steps.map((s, i) => (
        <div class={`step reveal reveal-${i + 1}`} style={`--c: ${s.color}`}>
          <div class="step-bg"></div>
          <div class="step-num"><span class="num-box">{s.num}</span></div>
          <div class="step-content">
            <h4>{s.title}</h4>
            <p set:html={s.body.replace('Black Sheep', '<strong style="color:#ffffff;font-weight:700">Black Sheep</strong>')}></p>
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top: 52px" class="reveal">
      <a href="/how-to-play/" class="btn btn-cyan">Read full rules</a>
    </div>
  </div>
</section>

<style>
  .how-title { font-size: clamp(36px, 4.8vw, 72px); }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 52px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  /* ── Card ── */
  .step {
    position: relative;
    height: 300px;
    overflow: hidden;
    border-right: 1px solid rgba(255,255,255,0.08);
    cursor: default;
    background: var(--bsp-ink);
  }
  .step:last-child { border-right: none; }

  /* Top accent bar slides in on hover */
  .step-bg {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--c);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2;
  }
  .step:hover .step-bg { transform: scaleX(1); }

  /* Number — centred square box at rest, pins top-left on hover */
  .step-num {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: top 0.42s cubic-bezier(0.4, 0, 0.2, 1),
                left 0.42s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .num-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    border: 3px solid var(--c);
    font-family: var(--font-display);
    font-size: 52px;
    line-height: 1;
    color: var(--c);
    transition: border-color 0.3s ease,
                width 0.42s cubic-bezier(0.4, 0, 0.2, 1),
                height 0.42s cubic-bezier(0.4, 0, 0.2, 1),
                font-size 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .step:hover .step-num {
    top: 24px;
    left: 24px;
    transform: translate(0, 0);
  }
  .step:hover .num-box {
    width: auto;
    height: auto;
    font-size: 48px;
    border-color: transparent;
  }

  /* Content — hidden at rest */
  .step-content {
    position: absolute;
    z-index: 1;
    bottom: 28px;
    left: 24px;
    right: 24px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease 0.18s, transform 0.3s ease 0.18s;
  }
  .step:hover .step-content {
    opacity: 1;
    transform: translateY(0);
  }

  .step h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 26px;
    line-height: 1.2;
    color: var(--bsp-white);
    margin-bottom: 12px;
  }
  .step p {
    font-size: 19px;
    color: rgba(255,255,255,0.72);
    line-height: 1.6;
  }
  .step p strong { color: var(--bsp-white); font-weight: 700; }

  @media (max-width: 1100px) {
    .steps-grid { grid-template-columns: 1fr 1fr; }
    .step { height: 240px; }
    .step-bg { transform: scaleX(1); }
    .step-num { top: 24px; left: 24px; transform: translate(0,0); }
    .num-box { width: auto; height: auto; font-size: 40px; border-color: transparent; }
    .step-content { opacity: 1; transform: none; }
  }
  @media (max-width: 620px) {
    .steps-grid { grid-template-columns: 1fr; }
    .step { height: 200px; }
  }
</style>
