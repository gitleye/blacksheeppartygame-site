---
import { getCollection } from 'astro:content';

// Pull all demo cards from src/content/cards/*.json and sort by `order`
const cards = (await getCollection('cards')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="cards-showcase" id="cards">
  <div class="section-inner">
    <div class="reveal">
      <span class="eyebrow">Inside the box</span>
      <h2 class="section-title">150 questions.<br/>Zero <span class="accent-pink">comfort zone</span>.</h2>
    </div>
    <div class="cards-track-wrap">
      <div class="cards-track">
        {[...cards, ...cards].map((c, i) => (
          <div class="flip-card" tabindex="0" aria-hidden={i >= cards.length ? "true" : "false"}>
            <div class="flip-inner">
              <div class="flip-face flip-front">
                <img
                  src={`/images/cards/front/${c.data.number}.webp`}
                  alt={`Card #${c.data.number}: ${c.data.question}`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="flip-face flip-back">
                <img
                  src={`/images/cards/back/${c.data.number}.webp`}
                  alt={`Card #${c.data.number} back`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cards-showcase {
    background: linear-gradient(180deg, var(--bsp-black) 0%, var(--bsp-deep) 100%);
    overflow: hidden;
  }
  .cards-track-wrap {
    margin-top: 64px;
    overflow: hidden;
  }
  .cards-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: cards-slide 60s linear infinite;
  }

  .cards-track:has(.flip-card:hover),
  .cards-track:has(.flip-card.flipped) { animation-play-state: paused; }

  @keyframes cards-slide {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .flip-card {
    flex-shrink: 0;
    width: 260px;
    aspect-ratio: 2/3;
    perspective: 1000px;
    cursor: pointer;
  }
  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-inner,
  .flip-card.flipped .flip-inner { transform: rotateY(180deg); }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .flip-front { background: var(--bsp-deep); }
  .flip-back  { transform: rotateY(180deg); background: var(--bsp-deep); }

  .flip-face img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 620px) { .flip-card { width: 200px; } }
</style>

<script>
  document.querySelectorAll('.flip-card').forEach((card) => {
    card.addEventListener('click', () => card.classList.toggle('flipped'));
  });
</script>
