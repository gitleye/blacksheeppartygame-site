---
import { getCollection } from 'astro:content';

// Pull all demo cards from src/content/cards/*.json and sort by `order`
const cards = (await getCollection('cards')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="cards-showcase" id="cards">
  <div class="section-inner">
    <div class="reveal">
      <span class="eyebrow">Inside the box</span>
      <h2 class="section-title">150 questions.<br/>Zero <span class="accent-pink">comfort zone</span>.</h2>
    </div>
    <div class="cards-grid">
      {cards.map((c, i) => (
        <div class={`flip-card reveal reveal-${(i % 4) + 1}`} tabindex="0">
          <div class="flip-inner">
            <div class="flip-face flip-front">
              <img
                src={`/images/cards/front/${c.data.number}.webp`}
                alt={`Card #${c.data.number}: ${c.data.question}`}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="flip-face flip-back">
              <img
                src={`/images/cards/back/${c.data.number}.webp`}
                alt={`Card #${c.data.number} back`}
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="flip-hint">hover or tap to flip</div>
  </div>
</section>

<style>
  .cards-showcase {
    background: linear-gradient(180deg, var(--bsp-black) 0%, var(--bsp-deep) 100%);
    overflow: hidden;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 18px;
    margin-top: 64px;
  }
  .flip-card {
    aspect-ratio: 2/3;
    perspective: 1000px;
    cursor: pointer;
  }
  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-inner,
  .flip-card.flipped .flip-inner { transform: rotateY(180deg); }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .flip-front { background: var(--bsp-deep); }
  .flip-back  { transform: rotateY(180deg); background: var(--bsp-deep); }

  .flip-face img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .flip-hint {
    margin-top: 40px;
    font-family: var(--font-marker);
    font-size: 20px;
    color: var(--bsp-cyan);
    text-align: center;
    opacity: 0.7;
  }
  .flip-hint::before { content: '→ '; }
  .flip-hint::after  { content: ' ←'; }

  @media (max-width: 1100px) { .cards-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 620px)  { .cards-grid { grid-template-columns: 1fr 1fr; } }
</style>
