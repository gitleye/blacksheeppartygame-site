---
import { getCollection } from 'astro:content';
const cards = (await getCollection('cards')).sort((a, b) => a.data.order - b.data.order);
const track = [...cards, ...cards]; // doubled for seamless loop
---
<section class="cards-showcase" id="cards">
  <div class="section-inner">
    <div class="reveal">
      <span class="eyebrow">Inside the box</span>
      <h2 class="section-title">150 questions.<br/>Zero <span class="accent-pink">comfort zone</span>.</h2>
    </div>
  </div>

  <div class="carousel-wrap">
    <button class="carousel-btn carousel-prev" aria-label="Previous cards">&#8592;</button>
    <div class="carousel-viewport" id="carouselViewport">
      <div class="carousel-track" id="carouselTrack">
        {track.map((c, i) => (
          <div class="flip-card" tabindex="0" data-index={i}>
            <div class="flip-inner">
              <div class="flip-face flip-front">
                <img
                  src={`/images/cards/front/${c.data.number}.webp`}
                  alt={`Card #${c.data.number}: ${c.data.question}`}
                  loading="lazy" decoding="async"
                />
              </div>
              <div class="flip-face flip-back">
                <img
                  src={`/images/cards/back/${c.data.number}.webp`}
                  alt={`Card #${c.data.number} back`}
                  loading="lazy" decoding="async"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <button class="carousel-btn carousel-next" aria-label="Next cards">&#8594;</button>
  </div>

  <div class="flip-hint">tap or hover a card to flip</div>
</section>

<script>
  const track = document.getElementById('carouselTrack');
  const viewport = document.getElementById('carouselViewport');
  if (track && viewport) {
    const CARD_W = 220 + 16; // card width + gap
    const HALF = track.children.length / 2;

    // Auto-scroll
    let offset = 0;
    let paused = false;
    let animId;

    function step() {
      if (!paused) {
        offset += 0.5;
        // Seamless loop: when we've scrolled past the first half, jump back
        if (offset >= CARD_W * HALF) offset -= CARD_W * HALF;
        track.style.transform = `translateX(-${offset}px)`;
      }
      animId = requestAnimationFrame(step);
    }
    animId = requestAnimationFrame(step);

    // Pause on hover
    viewport.addEventListener('mouseenter', () => paused = true);
    viewport.addEventListener('mouseleave', () => paused = false);

    // Arrow buttons — jump by 2 cards
    document.querySelector('.carousel-prev')?.addEventListener('click', () => {
      offset = Math.max(0, offset - CARD_W * 2);
      track.style.transform = `translateX(-${offset}px)`;
    });
    document.querySelector('.carousel-next')?.addEventListener('click', () => {
      offset += CARD_W * 2;
      if (offset >= CARD_W * HALF) offset -= CARD_W * HALF;
      track.style.transform = `translateX(-${offset}px)`;
    });

    // Flip on click/tap
    track.addEventListener('click', (e) => {
      const card = (e.target as Element).closest('.flip-card');
      if (card) {
        paused = true;
        card.classList.toggle('flipped');
        setTimeout(() => paused = false, 1200);
      }
    });
  }
</script>

<style>
  .cards-showcase {
    background: linear-gradient(180deg, var(--bsp-black) 0%, var(--bsp-deep) 100%);
    overflow: hidden;
    padding-bottom: 56px;
  }

  .carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 56px;
  }

  .carousel-btn {
    flex-shrink: 0;
    width: 52px; height: 52px;
    background: var(--bsp-ink);
    border: 1px solid rgba(255,255,255,0.18);
    color: var(--bsp-white);
    font-size: 22px;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s;
    z-index: 10;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }
  .carousel-prev { left: 16px; }
  .carousel-next { right: 16px; }
  .carousel-btn:hover {
    background: var(--bsp-cyan);
    border-color: var(--bsp-cyan);
    color: var(--bsp-black);
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-viewport {
    overflow: hidden;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    will-change: transform;
    padding: 20px 0;
  }

  .flip-card {
    flex-shrink: 0;
    width: 220px;
    aspect-ratio: 2/3;
    perspective: 1000px;
    cursor: pointer;
  }
  .flip-inner {
    position: relative;
    width: 100%; height: 100%;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-inner,
  .flip-card.flipped .flip-inner { transform: rotateY(180deg); }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  .flip-front { background: var(--bsp-deep); }
  .flip-back { transform: rotateY(180deg); background: var(--bsp-deep); }
  .flip-face img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .flip-hint {
    text-align: center;
    margin-top: 32px;
    font-family: var(--font-marker);
    font-size: 18px;
    color: var(--bsp-cyan);
    opacity: 0.7;
  }
  .flip-hint::before { content: '→ '; }
  .flip-hint::after  { content: ' ←'; }
</style>
