---
import { getCollection } from 'astro:content';

// Pull all demo cards from src/content/cards/*.json and sort by `order`
const cards = (await getCollection('cards')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="cards-showcase" id="cards">
  <div class="section-inner">
    <div class="reveal">
      <span class="eyebrow">Inside the box</span>
      <h2 class="section-title">150 questions.<br/>Zero <span class="accent-pink">comfort zone</span>.</h2>
    </div>
    <div class="cards-grid">
      {cards.map((c, i) => (
        <div class={`flip-card reveal reveal-${(i % 4) + 1}`} tabindex="0">
          <div class="flip-inner">
            <div class={`flip-face fc-${c.data.palette}-front`}>
              <div class="label">{c.data.type === 'yes-no' ? 'Yes / No' : 'Nominate'}</div>
              <div class="q">{c.data.question}</div>
              <div class="num">#{c.data.number}</div>
            </div>
            <div class={`flip-face flip-back fc-${c.data.palette}-back`}>
              <div class="label">Black Sheep</div>
              <div class="q back-mark">{c.data.type === 'nominate' ? 'A / B' : '✦'}</div>
              <div class="num">Tap to flip back</div>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="flip-hint">hover or tap to flip</div>
  </div>
</section>

<style>
  .cards-showcase {
    background: linear-gradient(180deg, var(--bsp-black) 0%, var(--bsp-deep) 100%);
    overflow: hidden;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 18px;
    margin-top: 64px;
  }
  .flip-card {
    aspect-ratio: 2/3;
    perspective: 1000px;
    cursor: pointer;
  }
  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-inner,
  .flip-card.flipped .flip-inner { transform: rotateY(180deg); }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 14px;
    padding: 22px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .flip-back { transform: rotateY(180deg); }

  .flip-face .label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .flip-face .q {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.1;
    letter-spacing: -0.2px;
  }
  .flip-face .back-mark {
    font-size: 32px;
    text-align: center;
    align-self: center;
    text-transform: uppercase;
  }
  .flip-face .num {
    font-family: var(--font-display);
    font-size: 22px;
    opacity: 0.5;
  }
  .flip-back .num { text-align: center; font-size: 11px; letter-spacing: 1px; font-family: var(--font-body); }

  /* Palettes */
  .fc-cyan-front { background: var(--bsp-cyan); color: var(--bsp-black); }
  .fc-cyan-back  { background: var(--bsp-black); color: var(--bsp-cyan); border: 2px solid var(--bsp-cyan); }
  .fc-pink-front { background: var(--bsp-pink); color: var(--bsp-white); }
  .fc-pink-back  { background: var(--bsp-black); color: var(--bsp-pink); border: 2px solid var(--bsp-pink); }
  .fc-white-front { background: var(--bsp-white); color: var(--bsp-black); }
  .fc-white-back  { background: var(--bsp-black); color: var(--bsp-white); border: 2px solid var(--bsp-white); }
  .fc-cream-front { background: var(--bsp-cream); color: var(--bsp-black); }
  .fc-cream-back  { background: var(--bsp-black); color: var(--bsp-cream); border: 2px solid var(--bsp-cream); }
  .fc-black-front { background: var(--bsp-black); color: var(--bsp-white); border: 2px solid var(--bsp-cyan); }
  .fc-black-back  { background: var(--bsp-cyan); color: var(--bsp-black); }

  .flip-hint {
    margin-top: 40px;
    font-family: var(--font-marker);
    font-size: 20px;
    color: var(--bsp-cyan);
    text-align: center;
    opacity: 0.7;
  }
  .flip-hint::before { content: '→ '; }
  .flip-hint::after  { content: ' ←'; }

  @media (max-width: 1100px) { .cards-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 620px)  { .cards-grid { grid-template-columns: 1fr 1fr; } }
</style>
