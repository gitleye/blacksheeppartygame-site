---
import { getCollection } from 'astro:content';

export interface Props {
  /** How many testimonials to show; default 6 (featured first) */
  limit?: number;
}
const { limit = 6 } = Astro.props;

const all = await getCollection('testimonials');
const sorted = all.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.order - b.data.order;
});
const list = sorted.slice(0, limit);
---
<section class="testimonials" id="reviews">
  <div class="testimonials-inner">
    <div class="reveal">
      <span class="eyebrow">Hear it from the herd</span>
      <h2 class="section-title">Reviews we're<br/>not <span class="accent-cyan">paying for</span>.</h2>
    </div>
    <div class="test-grid">
      {list.map(async (t, i) => {
        const { Content } = await t.render();
        return (
          <div class={`testimonial reveal reveal-${(i % 3) + 1}`}>
            <div class="stars">{'★ '.repeat(t.data.rating).trim()}</div>
            <div class="quote"><Content /></div>
            <div class="by">— {t.data.author}</div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--bsp-ink);
    padding-top: 120px;
    padding-bottom: 120px;
  }
  .testimonials-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }
  .test-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 64px;
  }
  .testimonial {
    background: var(--bsp-black);
    padding: 40px 34px;
    border-radius: 4px;
    position: relative;
    border-left: 4px solid var(--bsp-cyan);
    transition: transform 0.3s;
  }
  .testimonial:hover { transform: translateY(-6px); }
  .testimonial:nth-child(3n + 2) { border-left-color: var(--bsp-pink); }
  .testimonial:nth-child(3n + 3) { border-left-color: var(--bsp-white); }
  .stars {
    color: var(--bsp-cyan);
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 16px;
  }
  .quote {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.2;
    margin-bottom: 28px;
    position: relative;
    letter-spacing: -0.3px;
  }
  .quote :global(p) { margin: 0; }
  .quote::before {
    content: '\201C';
    position: absolute;
    top: -56px;
    left: -8px;
    font-family: var(--font-display);
    font-size: 110px;
    color: var(--bsp-cyan);
    opacity: 0.25;
    line-height: 1;
  }
  .testimonial:nth-child(3n + 2) .quote::before { color: var(--bsp-pink); }
  .by {
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 1100px) { .test-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .test-grid { grid-template-columns: 1fr; } }
</style>
