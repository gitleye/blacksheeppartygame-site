---
import { getCollection } from 'astro:content';

const all = await getCollection('testimonials');
const sorted = all.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.order - b.data.order;
});

const rendered = await Promise.all(sorted.map(async (t) => {
  const { Content } = await t.render();
  return { t, Content };
}));
---
<section class="testimonials" id="reviews">
  <div class="section-inner">

    <div class="t-header reveal">
      <div>
        <span class="eyebrow">Hear it from the herd</span>
        <h2 class="section-title">Reviews we're<br/>not <span class="accent-cyan">paying for</span>.</h2>
      </div>
      <div class="t-controls">
        <button class="t-btn" id="tPrev" aria-label="Previous">&#8592;</button>
        <button class="t-btn" id="tNext" aria-label="Next">&#8594;</button>
      </div>
    </div>

    <div class="t-wrap" id="tWrap">
      <div class="t-track" id="tTrack">
        {[...rendered, ...rendered].map(({ t, Content }, i) => (
          <div class="t-card" aria-hidden={i >= rendered.length ? 'true' : 'false'}>
            <div class="stars">{'★ '.repeat(t.data.rating).trim()}</div>
            <div class="quote"><Content /></div>
            <div class="by">— {t.data.author}</div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .testimonials { background: var(--bsp-ink); }

  .t-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  .t-controls { display: flex; gap: 12px; padding-bottom: 8px; }
  .t-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
    background: transparent;
    color: var(--bsp-white);
    font-size: 22px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    line-height: 1;
  }
  .t-btn:hover {
    background: var(--bsp-cyan);
    border-color: var(--bsp-cyan);
    color: var(--bsp-black);
    transform: scale(1.08);
  }
  .t-btn:active { transform: scale(0.95); }

  .t-wrap { overflow: hidden; }
  .t-track {
    display: flex;
    gap: 24px;
    width: max-content;
    will-change: transform;
    align-items: stretch;
  }

  .t-card {
    flex-shrink: 0;
    width: 380px;
    background: var(--bsp-black);
    padding: 36px 32px;
    border-radius: 4px;
    border-left: 4px solid var(--bsp-cyan);
    display: flex;
    flex-direction: column;
  }
  .t-card:nth-child(3n + 2) { border-left-color: var(--bsp-pink); }
  .t-card:nth-child(3n + 3) { border-left-color: rgba(255,255,255,0.4); }

  .stars {
    color: var(--bsp-cyan);
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 16px;
    flex-shrink: 0;
  }
  .quote {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.2;
    margin-bottom: 24px;
    flex: 1;
    position: relative;
    letter-spacing: -0.3px;
  }
  .quote :global(p) { margin: 0; }
  .quote::before {
    content: '\201C';
    position: absolute;
    top: -52px;
    left: -8px;
    font-family: var(--font-display);
    font-size: 110px;
    color: var(--bsp-cyan);
    opacity: 0.18;
    line-height: 1;
    pointer-events: none;
  }
  .t-card:nth-child(3n + 2) .quote::before { color: var(--bsp-pink); }

  .by {
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }

  @media (max-width: 620px) { .t-card { width: 300px; } }
</style>

<script>
  const track = document.getElementById('tTrack') as HTMLElement;
  const wrap  = document.getElementById('tWrap')  as HTMLElement;
  const prev  = document.getElementById('tPrev')  as HTMLButtonElement;
  const next  = document.getElementById('tNext')  as HTMLButtonElement;

  if (track && wrap && prev && next) {
    const CARD_W = 380 + 24;
    const COUNT  = track.children.length / 2;
    const LOOP_W = COUNT * CARD_W;
    const SPEED  = 0.45;

    let pos    = 0;
    let paused = false;

    (function tick() {
      if (!paused) {
        pos += SPEED;
        if (pos >= LOOP_W) pos -= LOOP_W;
        track.style.transform = `translateX(-${pos}px)`;
      }
      requestAnimationFrame(tick);
    })();

    wrap.addEventListener('mouseenter', () => { paused = true; });
    wrap.addEventListener('mouseleave', () => { paused = false; });

    function snap(dir: 1 | -1) {
      paused = true;
      pos += CARD_W * dir;
      if (pos < 0) pos += LOOP_W;
      if (pos >= LOOP_W) pos -= LOOP_W;
      track.style.transition = 'transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94)';
      track.style.transform  = `translateX(-${pos}px)`;
      setTimeout(() => { track.style.transition = ''; paused = false; }, 380);
    }

    prev.addEventListener('click', () => snap(-1));
    next.addEventListener('click', () => snap(1));
  }
</script>
