---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Black Sheep Party Game" description="This page has gone rogue.">
  <section class="notfound">
    <div class="inner">
      <div class="big-404">404</div>
      <h1>This one <span class="pink">went rogue</span>.</h1>
      <p>
        The page you're looking for doesn't exist, has moved, or was never here to begin with.
        Much like your least-trustworthy friend.
      </p>
      <div class="ctas">
        <a href="/" class="btn">← Back to home</a>
        <a href="https://shop.blacksheeppartygame.com" class="btn btn-outline">Shop the game</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px var(--content-padding);
    position: relative;
    z-index: 2;
  }
  .inner {
    max-width: 700px;
    text-align: center;
  }
  .big-404 {
    font-family: var(--font-display);
    font-size: clamp(140px, 25vw, 340px);
    line-height: 0.85;
    color: transparent;
    -webkit-text-stroke: 3px var(--bsp-cyan);
    letter-spacing: -8px;
    margin-bottom: 20px;
  }
  .notfound h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.95;
    letter-spacing: -1px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .notfound h1 .pink { color: var(--bsp-pink); }
  .notfound p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 36px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .ctas { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
</style>
