---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import VideoSection from '../components/VideoSection.astro';
import WhyPlay from '../components/WhyPlay.astro';
import HowToPlay from '../components/HowToPlay.astro';
import CardsShowcase from '../components/CardsShowcase.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';
---
<BaseLayout title="Black Sheep Party Game — Get Everyone Talking">
  <Hero />
  <Marquee items={['Get Everyone Talking', 'Play Black Sheep', 'You Win If You Don\'t Lose!']} variant="cyan" />
  <WhyPlay />
  <HowToPlay />
  <VideoSection />
  <CardsShowcase />
  <Testimonials />
  <FAQ />
  <CTABand />
</BaseLayout>
