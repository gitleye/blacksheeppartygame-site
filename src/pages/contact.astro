---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
---
<BaseLayout
  title="Contact — Black Sheep Party Game"
  description="Get in touch with the Black Sheep team — wholesale, press, card ideas, or just saying hi."
>
  <section class="page-hero">
    <div class="section-inner">
      <span class="eyebrow">Get in touch</span>
      <h1 class="page-title">Say <span class="accent-cyan">hi</span>.</h1>
      <p class="lede">
        Whether you're reporting a problem, pitching a card idea, or asking about wholesale — we read every message.
      </p>
    </div>
  </section>

  <section class="contact-section">
    <div class="section-inner contact-grid">
      <div class="contact-col reveal">
        <h2 class="col-heading">Quick links</h2>
        <ul class="contact-list">
          <li>
            <span class="label">Order help</span>
            <a href="/support/">Visit our support page</a>
          </li>
          <li>
            <span class="label">Rules questions</span>
            <a href="/how-to-play/">See how to play</a>
          </li>
          <li>
            <span class="label">Card ideas</span>
            <a href="#form">Use the form</a>
          </li>
          <li>
            <span class="label">Wholesale</span>
            <a href="#form">Use the form</a>
          </li>
          <li>
            <span class="label">Press &amp; partnerships</span>
            <a href="#form">Use the form</a>
          </li>
        </ul>

        <h2 class="col-heading" style="margin-top: 48px">Socials</h2>
        <div class="socials">
          <a href="https://instagram.com/blacksheeppartygame/" target="_blank" rel="noopener">Instagram</a>
          <a href="https://tiktok.com/@blacksheeppartygame_" target="_blank" rel="noopener">TikTok</a>
          <a href="https://facebook.com/profile.php?id=61557441800367" target="_blank" rel="noopener">Facebook</a>
          <a href="https://youtube.com/@blacksheeppartygame/shorts" target="_blank" rel="noopener">YouTube</a>
        </div>
      </div>

      <div class="contact-col reveal reveal-2" id="form">
        <h2 class="col-heading">Send us a message</h2>
        <form class="contact-form" action="/api/contact" method="POST">
          <label>
            <span>Your name</span>
            <input type="text" name="name" required />
          </label>
          <label>
            <span>Email</span>
            <input type="email" name="email" required />
          </label>
          <label>
            <span>What's this about?</span>
            <select name="topic">
              <option value="general">General question</option>
              <option value="order">Order / shipping</option>
              <option value="card-idea">Card idea</option>
              <option value="wholesale">Wholesale</option>
              <option value="press">Press / partnership</option>
              <option value="other">Something else</option>
            </select>
          </label>
          <label>
            <span>Message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button type="submit" class="btn">Send message →</button>
          <p class="form-note">
            We reply within 48 hours. For urgent order issues, include your order number.
          </p>
        </form>
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>

<style>
  .page-hero {
    padding-top: 80px;
    padding-bottom: 0;
    position: relative;
    z-index: 2;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 120px);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
  }
  .accent-cyan { color: var(--bsp-cyan); }
  .lede {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.75);
    max-width: 600px;
  }

  .contact-section { background: var(--bsp-ink); position: relative; z-index: 2; }
  .contact-section .section-inner { padding: 80px var(--content-padding); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    padding: 80px var(--content-padding) !important;
  }
  .contact-col {
    background: var(--bsp-black);
    padding: 40px 36px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
  }
  .col-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1;
    margin-bottom: 28px;
    color: var(--bsp-cyan);
    letter-spacing: -0.5px;
  }
  .contact-list {
    list-style: none;
    padding: 0;
  }
  .contact-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 15px;
  }
  .contact-list .label {
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 12px;
  }
  .contact-list a {
    color: var(--bsp-cyan);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-list a:hover { color: var(--bsp-pink); }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .socials a {
    padding: 10px 16px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--bsp-white);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .socials a:hover {
    background: var(--bsp-cyan);
    border-color: var(--bsp-cyan);
    color: var(--bsp-black);
  }

  .contact-form { display: flex; flex-direction: column; gap: 18px; }
  .contact-form label { display: flex; flex-direction: column; gap: 8px; }
  .contact-form span {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    background: var(--bsp-ink);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--bsp-white);
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 15px;
    border-radius: 2px;
    transition: border-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--bsp-cyan);
  }
  .contact-form textarea { resize: vertical; min-height: 120px; }
  .contact-form button { align-self: flex-start; margin-top: 8px; }
  .form-note { font-size: 13px; color: rgba(255, 255, 255, 0.5); margin-top: 4px; }

  @media (max-width: 1100px) {
    .contact-grid { grid-template-columns: 1fr; gap: 30px; }
  }
</style>
