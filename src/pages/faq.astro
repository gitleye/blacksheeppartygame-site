---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';
---
<BaseLayout
  title="FAQ — Black Sheep Party Game"
  description="Frequently asked questions about Black Sheep — shipping, expansions, wholesale, and more."
>
  <div class="faq-intro">
    <div class="section-inner">
      <p class="faq-note">Got a question we haven't answered? <a href="/contact/">Drop us a message</a>.</p>
    </div>
  </div>
  <FAQ />
  <CTABand />
</BaseLayout>

<style>
  .faq-intro {
    padding-top: 56px;
    padding-bottom: 0;
    position: relative;
    z-index: 2;
  }
  .faq-note {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.65);
  }
  .faq-note a {
    color: var(--bsp-cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
